# Frontend Dockerfile
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY apps/frontend/package*.json ./

# Install dependencies
RUN npm ci

# Copy source
COPY apps/frontend/src ./src
COPY apps/frontend/tsconfig.json ./
COPY apps/frontend/next.config.js ./

EXPOSE 3000

CMD ["npm", "run", "dev"]
