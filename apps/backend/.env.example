# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=payforms
DB_POOL_MAX=50
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Paystack
PAYSTACK_PUBLIC_KEY=pk_live_your_public_key_here
PAYSTACK_SECRET_KEY=sk_live_your_secret_key_here
PAYSTACK_SANDBOX_MODE=true

# Email Provider (sendgrid | mailgun | brevo)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@payforms.app
EMAIL_FROM_NAME=Payforms

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@payforms.app

# Mailgun
MAILGUN_API_KEY=your_mailgun_api_key_here
MAILGUN_DOMAIN=mg.example.com
MAILGUN_BASE_URL=https://api.mailgun.net/v3
MAILGUN_FROM=noreply@payforms.app

# Brevo
BREVO_API_KEY=your_brevo_api_key_here
BREVO_FROM=noreply@payforms.app
BREVO_API_BASE_URL=https://api.brevo.com/v3

# Paystack Callback
PAYSTACK_CALLBACK_URL=http://localhost:3001/public/payments/callback

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Public API URL (used for widget endpoint generation behind proxies)
PUBLIC_API_BASE_URL=http://localhost:3001

# Tenant Routing
# Base domain used for resolving organization subdomains from request host
# Example: for school.payforms.com, set TENANT_BASE_DOMAIN=payforms.com
TENANT_BASE_DOMAIN=

# Cache
CACHE_DEFAULT_TTL_SECONDS=120
CACHE_REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT_MS=10000
TEST_EMAIL_TO=

# File Storage (S3)
AWS_S3_BUCKET=your_bucket_name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Supabase Storage (S3-compatible alternative)
SUPABASE_URL=https://xyzcompany.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=your_bucket_name
