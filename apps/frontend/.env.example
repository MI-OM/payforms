# Frontend Configuration
# Copy to .env.local for local development
# For production, set these in Vercel dashboard

# Application URL (used for callback URLs and public links)
NEXT_PUBLIC_APP_URL=http://localhost:5701

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Application Name
NEXT_PUBLIC_APP_NAME=Payforms

# Production example:
# NEXT_PUBLIC_APP_URL=https://payforms.com.ng
# NEXT_PUBLIC_API_URL=https://api.payforms.com.ng

